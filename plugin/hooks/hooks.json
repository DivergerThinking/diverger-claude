{
  "PreToolUse": {
    "Write": [
      {
        "type": "command",
        "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/secret-scanner.sh",
        "timeout": 10,
        "statusMessage": "Scanning for secrets..."
      }
    ],
    "Bash": [
      {
        "type": "command",
        "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/destructive-cmd-blocker.sh",
        "timeout": 10,
        "statusMessage": "Checking for destructive commands..."
      },
      {
        "type": "command",
        "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/pre-commit-validator.sh",
        "timeout": 30,
        "statusMessage": "Validating commit prerequisites..."
      }
    ]
  },
  "PostToolUse": {
    "Write": [
      {
        "type": "command",
        "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/check-long-lines.sh",
        "timeout": 5,
        "statusMessage": "Checking line lengths..."
      },
      {
        "type": "command",
        "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/check-trailing-newline.sh",
        "timeout": 5,
        "statusMessage": "Checking trailing newline..."
      },
      {
        "type": "command",
        "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/error-tracker.sh",
        "timeout": 5,
        "statusMessage": "Tracking errors..."
      }
    ],
    "Bash": [
      {
        "type": "command",
        "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/error-tracker.sh",
        "timeout": 5,
        "statusMessage": "Tracking errors for learning..."
      }
    ],
    "Edit": [
      {
        "type": "command",
        "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/error-tracker.sh",
        "timeout": 5,
        "statusMessage": "Tracking errors..."
      }
    ]
  },
  "SessionEnd": [
    {
      "type": "command",
      "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/session-learner.sh",
      "timeout": 10,
      "statusMessage": "Processing session learnings..."
    }
  ]
}
