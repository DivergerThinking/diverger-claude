{
  "name": "@divergerthinking/diverger-claude",
  "version": "3.5.1",
  "description": "Herramienta para detectar stack tecnológico y generar configuración .claude/ adaptada",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "diverger": "dist/index.js",
    "diverger-claude": "dist/index.js",
    "diverger-mcp": "dist/mcp/server.js"
  },
  "files": [
    "dist",
    "commands",
    "agents",
    "skills",
    "hooks"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "vitest run tests/e2e/",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "build:plugin": "npm run build && tsx scripts/build-plugin.ts",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@inquirer/prompts": "^8.3.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "deepmerge-ts": "^7.1.5",
    "diff": "^8.0.3",
    "fast-glob": "^3.3.3",
    "fast-xml-parser": "^5.4.2",
    "js-yaml": "^4.1.1",
    "ora": "^9.3.0",
    "smol-toml": "^1.6.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.3.3",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^10.0.2",
    "tsup": "^8.3.6",
    "tsx": "^4.7.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/DivergerThinking/diverger-claude.git"
  },
  "keywords": [
    "claude-code",
    "claude",
    "developer-tools",
    "configuration",
    "best-practices"
  ],
  "license": "UNLICENSED"
}
