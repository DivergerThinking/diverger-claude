{
  "name": "@divergerthinking/diverger-claude",
  "version": "1.1.0",
  "description": "Herramienta para detectar stack tecnológico y generar configuración .claude/ adaptada",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "diverger": "dist/index.js",
    "diverger-claude": "dist/index.js",
    "diverger-mcp": "dist/mcp/server.js"
  },
  "files": [
    "dist",
    "commands",
    "agents",
    "skills",
    "hooks"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "vitest run tests/e2e/",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "build:plugin": "npm run build && tsx scripts/build-plugin.ts",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "deepmerge-ts": "^7.1.3",
    "diff": "^7.0.0",
    "fast-glob": "^3.3.3",
    "fast-xml-parser": "^4.5.1",
    "@inquirer/prompts": "^7.0.0",
    "js-yaml": "^4.1.0",
    "ora": "^8.2.0",
    "smol-toml": "^1.3.1",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@types/diff": "^6.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.13.0",
    "eslint": "^9.0.0",
    "tsup": "^8.3.6",
    "typescript": "^5.7.3",
    "tsx": "^4.7.0",
    "vitest": "^3.0.5"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/DivergerThinking/diverger-claude.git"
  },
  "keywords": [
    "claude-code",
    "claude",
    "developer-tools",
    "configuration",
    "best-practices"
  ],
  "license": "UNLICENSED"
}
